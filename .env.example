APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
OCTANE_SERVER=roadrunner

SMS_BOMBER_URL=http://sms:8080
SMS_BOMBER_KEY=
EMAIL_BOMBER_URL=http://sms:8080
EMAIL_BOMBER_KEY=
CHANNEL_REACTION_URL=http://telegram-reporter:8000
CHANNEL_REACTION_TOKEN=
BOXAPI_USERNAME=
BOXAPI_PASSWORD=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Telegram Stars pricing
TELEGRAM_STAR_USD_VALUE=0.5

# NOWPayments
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_BEARER_TOKEN=
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
NOWPAYMENTS_PRICE_CURRENCY=usd
NOWPAYMENTS_PAY_CURRENCY=usdttrc20
NOWPAYMENTS_IPN_URL=
NOWPAYMENTS_SUCCESS_URL=
NOWPAYMENTS_CANCEL_URL=
NOWPAYMENTS_CONNECT_TIMEOUT=10
NOWPAYMENTS_TIMEOUT=30
# set to v4 to avoid ipv6 issues; leave empty to let curl decide
NOWPAYMENTS_FORCE_IP_RESOLVE=v4
NOWPAYMENTS_VERIFY_SSL=true
